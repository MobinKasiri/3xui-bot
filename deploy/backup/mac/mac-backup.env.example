# NC VPN — pull backup from Germany server to this Mac
# Copy to: ~/.config/nc-vpn/mac-backup.env

# Germany VPS
SERVER_HOST=91.107.177.122
SERVER_SSH_PORT=2222
SERVER_SSH_USER=root
SSH_IDENTITY_FILE=$HOME/.ssh/nc_germany

# Where backups are stored on this Mac (keep last 2 dated folders)
LOCAL_BACKUP_DIR=$HOME/NCBackups
KEEP_LOCAL_VERSIONS=2

# Remote script (installed by install-local-backup.sh on server)
REMOTE_BACKUP_SCRIPT=/usr/local/lib/nc-vpn-backup/run-local-backup.sh
REMOTE_EXPORT_DIR=/var/lib/nc-vpn-backup/export/latest
