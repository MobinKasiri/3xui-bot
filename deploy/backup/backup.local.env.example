# NC VPN — local backup (Mac pull, no cloud)
# Server: /etc/nc-vpn/backup.env

# ─── Paths on Germany server ─────────────────────────────────────────────────
BOT_ROOT=/opt/nexoranode-bot
PANEL_ROOT=/opt/nexoranode-panel
DATA_DIR=/opt/nexoranode-data
XUI_DIR=/usr/local/x-ui
XUI_CERT_DIR=/root/cert
ACME_DIR=/root/.acme.sh

# Export bundle for Mac rsync (keep last 2 versions on server)
LOCAL_EXPORT_DIR=/var/lib/nc-vpn-backup/export
KEEP_LOCAL_VERSIONS=3

# Optional: VPN deploy scripts on this server (copies scripts/xui-nodes.conf into backup meta)
# SCRIPTS_ROOT=/opt/VPN_project

# Optional: extra paths (comma-separated), e.g. subscription bridge, custom nginx site
# BACKUP_EXTRA_PATHS=/opt/sub-bridge,/etc/letsencrypt

# ─── 3X-UI PostgreSQL ────────────────────────────────────────────────────────
XUI_PG_HOST=127.0.0.1
XUI_PG_PORT=5432
XUI_PG_USER=kmQooIv0
XUI_PG_DB=xui
XUI_PG_PASSWORD=CHANGE_ME

# ─── Bot PostgreSQL (Docker) ─────────────────────────────────────────────────
BOT_PG_CONTAINER=nexoranode-postgres
BOT_PG_USER=nexora
BOT_PG_DB=nexorabot

LOG_FILE=/var/log/nc-vpn-backup.log

# Optional: Telegram alert on failure
# NOTIFY_TG_CHAT_ID=
